{
  "dashboard": {
    "title": "Database Metrics",
    "tags": ["database", "postgresql"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Active Connections",
        "targets": [
          {
            "expr": "pg_stat_activity_connections"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Database Size",
        "targets": [
          {
            "expr": "pg_database_size_bytes"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Query Performance",
        "targets": [
          {
            "expr": "rate(pg_stat_statements_query_time_seconds[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Cache Hit Ratio",
        "targets": [
          {
            "expr": "rate(pg_stat_user_tables_idx_blks_hit_total[5m]) / (rate(pg_stat_user_tables_idx_blks_hit_total[5m]) + rate(pg_stat_user_tables_idx_blks_read_total[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Transactions Per Second",
        "targets": [
          {
            "expr": "rate(pg_stat_user_tables_n_tup_ins_total[5m]) + rate(pg_stat_user_tables_n_tup_upd_total[5m]) + rate(pg_stat_user_tables_n_tup_del_total[5m])"
          }
        ],
        "type": "graph"
      }
    ]
  }
}
